{
  "name": "zhuqian",
  "displayName": "ZhuQian",
  "description": "Real-time labels highlighting for structured writing",
  "version": "0.1.1",
  "publisher": "angushushu",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/angushushu/zhuqian"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "license": "GPL-3.0-only",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:zq",
    "onLanguage:plaintext",
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "zq",
        "aliases": [
          "ZhuQian"
        ],
        "extensions": [
          ".zq"
        ]
      }
    ],
    "configuration": {
      "title": "ZhuQian (Custom Panel: [Open Settings](command:zhuqian.openSettings))",
      "properties": {
        "zhuqian.accentColorUi": {
          "type": "string",
          "default": "#0078d7",
          "format": "color-hex",
          "description": "Accent color for UI elements (Hex format, e.g. #0078d7)"
        },
        "zhuqian.accentColorHl": {
          "type": "string",
          "default": "#b4a000",
          "format": "color-hex",
          "description": "Accent color for headings and highlights (Hex format, e.g. #b4a000)"
        },
        "zhuqian.bgMain": {
          "type": "string",
          "default": "#f8f6eb",
          "format": "color-hex",
          "description": "Main editor background color (Hex format)"
        },
        "zhuqian.bgSide": {
          "type": "string",
          "default": "#eeece1",
          "format": "color-hex",
          "description": "Sidebar/Panel background color (Hex format)"
        },
        "zhuqian.textMain": {
          "type": "string",
          "default": "#1e1e1e",
          "format": "color-hex",
          "description": "Main text color (Hex format)"
        },
        "zhuqian.textSide": {
          "type": "string",
          "default": "#2d2d2d",
          "format": "color-hex",
          "description": "Sidebar/Panel text color (Hex format)"
        },
        "zhuqian.fontSize": {
          "type": "number",
          "default": 16,
          "description": "Base font size for ZhuQian (Applied as [zq] language setting)"
        },
        "zhuqian.fontFamily": {
          "type": "string",
          "default": "serif",
          "description": "Font family for ZhuQian (Applied as [zq] language setting)"
        },
        "zhuqian.markdownRender": {
          "type": "boolean",
          "default": false,
          "description": "Enable real-time markdown-style rendering enhancements"
        },
        "zhuqian.highlightRules": {
          "type": "string",
          "default": "",
          "description": "JSON string of custom highlight rules. If empty, uses default bracket rules."
        },
        "zhuqian.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable ZhuQian real-time syntax highlighting and labels."
        },
        "zhuqian.hideLabels": {
          "type": "boolean",
          "default": false,
          "description": "Hide semantic labels visually in the editor while keeping them in the text."
        },
        "zhuqian.levelColors": {
          "type": "array",
          "default": [
            [230, 80, 80],
            [80, 200, 80],
            [80, 80, 230],
            [230, 180, 50],
            [180, 80, 200],
            [80, 200, 200]
          ],
          "description": "Background colors for semantic label levels 1–6 (each item is an [R, G, B] array, 0–255)."
        }
      }
    },
    "commands": [
      {
        "command": "zhuqian.openSettings",
        "title": "ZhuQian: Open Visual Settings (Desktop Style)",
        "category": "ZhuQian"
      },
      {
        "command": "zhuqian.toggle",
        "title": "ZhuQian: Toggle Rendering",
        "category": "ZhuQian"
      },
      {
        "command": "zhuqian.copyCleanText",
        "title": "ZhuQian: Copy Clean Text (Remove Labels)",
        "category": "ZhuQian"
      },
      {
        "command": "zhuqian.toggleHideLabels",
        "title": "ZhuQian: Toggle Hide Labels (Reading Mode)",
        "category": "ZhuQian"
      }
    ],
    "keybindings": [
      {
        "command": "zhuqian.toggle",
        "key": "ctrl+alt+z",
        "mac": "cmd+alt+z",
        "when": "editorTextFocus"
      },
      {
        "command": "zhuqian.copyCleanText",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus"
      },
      {
        "command": "zhuqian.toggleHideLabels",
        "key": "ctrl+h",
        "mac": "cmd+h",
        "when": "editorTextFocus && resourceExtname == '.zq'"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "zhuqian.openSettings",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node -e \"require('fs').cpSync('src/pkg', 'out/pkg', {recursive: true})\"",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  }
}