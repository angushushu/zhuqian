{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "ZhuQian Extension Development",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceRoot}/zq-vscode"
			],
			"outFiles": [
				"${workspaceRoot}/zq-vscode/out/**/*.js"
			],
			"preLaunchTask": "compile-extension"
		}
	]
}
